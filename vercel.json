{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/chart-types/(.*)",
      "dest": "/chart-types/$1"
    },
    {
      "src": "/series-types/(.*)",
      "dest": "/series-types/$1"
    },
    {
      "src": "/conditions/(.*)",
      "dest": "/conditions/$1"
    },
    {
      "src": "/(.*).html",
      "dest": "/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
